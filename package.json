{
  "name": "tree-sitter-ispc",
  "version": "0.2.0",
  "description": "ISPC grammar for tree-sitter (based on C grammar)",
  "main": "bindings/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/tree-sitter-grammars/tree-sitter-ispc"
  },
  "author": "Fabian Wermelinger",
  "license": "MIT",
  "dependencies": {
    "nan": "^2.17.0"
  },
  "devDependencies": {
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cli": "^0.26.8"
  },
  "scripts": {
    "test": "tree-sitter test && tree-sitter parse examples/*.ispc --quiet --time",
    "test-windows": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.ispc",
      "file-types": [
        "ispc"
      ]
    }
  ]
}
